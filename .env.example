# Copy this file to .env and fill in real values. NEVER commit .env

# ---- Server ----
APP_BASE_URL=https://payroll-m365-demo.example.azurecontainerapps.io
PORT=8080
LOG_LEVEL=INFO

# ---- Bot Framework / Microsoft 365 Agents SDK ----
# Bot's Entra ID app registration (multi-tenant). Created during provisioning.
BOT_APP_ID=00000000-0000-0000-0000-000000000000
BOT_APP_PASSWORD=
BOT_TENANT_ID=common
# Single-tenant app type for demo simplicity; switch to MultiTenant for ISV scenario.
BOT_APP_TYPE=SingleTenant

# ---- Azure OpenAI (LangGraph backend) ----
AZURE_OPENAI_ENDPOINT=https://eastus2oai.openai.azure.com/openai/v1
AZURE_OPENAI_API_KEY=replace-me-rotate-after-demo
AZURE_OPENAI_DEPLOYMENT=gpt-5.2-chat
AZURE_OPENAI_API_VERSION=2024-10-21

# ---- Azure Communication Services (email) ----
# Connection string from "Keys" blade of the ACS resource
ACS_CONNECTION_STRING=
# Verified sender address (e.g. DoNotReply@<guid>.azurecomm.net)
ACS_SENDER_ADDRESS=

# ---- Demo personas ----
# Both roles played by the same M365 user for the demo
DEMO_USER_EMAIL=james.nguyen@microsoft.com
DEMO_USER_TENANT_ID=72f988bf-86f3-41af-91ab-2d7cd011db47
# AAD object id of the demo user — required for proactive auto-create of a Teams
# chat (Mode B delivery without the user having to say "hi" first). Look up via:
#   az ad user show --id <upn> --query id -o tsv
# The PayCycle bot app MUST already be installed in this user's personal scope.
DEMO_USER_AAD_OBJECT_ID=

# ---- Bot Framework Connector ----
# Service URL used for createConversation calls. Default works for any tenant.
BOT_SERVICE_URL=https://smba.trafficmanager.net/teams/

# ---- Actionable Email Originator ----
# Get this GUID after registering the sender at https://outlook.office.com/connectors/oam/publish
# Until registered, action buttons render but are disabled.
OAM_ORIGINATOR_ID=

# ---- Signed token (CTA links) ----
# Random 32-byte secret for signing magic-link tokens (HS256)
CTA_TOKEN_SECRET=please-generate-a-random-32-byte-string

# ---- Demo flags ----
ENABLE_DEMO_CONSOLE=true
